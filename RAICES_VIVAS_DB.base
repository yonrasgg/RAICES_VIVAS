views:
  - type: table
    name: Table
    order:
      - file.name
      - file.ctime
      - file.ext
      - file.folder
      - assignee
      - author
      - created
      - completed
      - date
      - due
      - id
      - started
      - status
      - updated
    sort: []
    limit: 25
  - type: cards
    name: View
    order:
      - file.name
      - tags
      - file.mtime
    image: banner_src
    imageAspectRatio: 0.6
